rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles — only the owner can read/write their own doc
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Plan reactions — readable by anyone, writable by authenticated users via backend
    match /planReactions/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Plan comments — readable by anyone, create by authenticated users, delete only by author
    match /planComments/{planId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
